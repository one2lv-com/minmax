  "description": "One2lvOS Phase 9 - Full Autonomous Delta Engine with Interplanetary Disk",
  "main": "opt/one2lv/ui/server.js",
  "type": "module",
  "scripts": {
    "start": "bash opt/one2lv/launch.sh",
    "start-phase9": "cd opt/one2lv && bash launch.sh",
    "start-disk": "cd interplanetary-disk && docker-compose up --build -d",
    "install": "./builder/quick-run.sh install",
    "install-deps": "sudo ./builder/quick-run.sh install-deps",
    "dev": "node opt/one2lv/ui/server.js",
    "council": "node opt/one2lv/ai/council/council.js",
    "ui": "node opt/one2lv/ui/server.js",
    "discovery": "node opt/one2lv/mesh/discovery.js",
    "build-iso": "cd iso-build && sudo ./build-iso.sh"
  },
  "keywords": [
    "autonomous",
    "multi-agent",
    "delta-engine",
    "3d-vector",
    "council",
    "rpc",
    "vector-db",
    "sandbox",
    "phase9",
    "interplanetary",
    "one2lvos",
    "docker"
  ],
